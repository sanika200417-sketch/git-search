{
  "name": "@forjd/git-search",
  "version": "1.1.0",
  "description": "Semantic search over git commit history — local embeddings, sqlite-vec, terminal UI",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "git-search": "src/index.ts"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/forjd/git-search.git"
  },
  "keywords": [
    "git",
    "search",
    "semantic-search",
    "tui",
    "embeddings",
    "sqlite",
    "vector-search",
    "cli"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "check": "bunx biome check src/",
    "fix": "bunx biome check --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.1",
    "@opentui/core": "^0.1.87",
    "sqlite-vec": "^0.1.6"
  }
}
